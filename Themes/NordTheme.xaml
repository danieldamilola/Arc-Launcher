<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================== Nord Theme Colors ==================== -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BgPage" Color="#2E3440" />
    <SolidColorBrush x:Key="BgSurface" Color="#3B4252" />
    <SolidColorBrush x:Key="BgElevated" Color="#434C5E" />
    <SolidColorBrush x:Key="BgPressed" Color="#4C566A" />
    <SolidColorBrush x:Key="BgInput" Color="#3B4252" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#D8DEE9" />
    <SolidColorBrush x:Key="TextSecondary" Color="#81A1C1" />
    <SolidColorBrush x:Key="TextMuted" Color="#4C566A" />

    <!-- Borders -->
    <SolidColorBrush x:Key="Border" Color="#434C5E" />
    <SolidColorBrush x:Key="BorderStrong" Color="#4C566A" />

    <!-- Accent (Nord Frost) -->
    <SolidColorBrush x:Key="Accent" Color="#88C0D0" />

    <!-- Semantic Colors -->
    <SolidColorBrush x:Key="Success" Color="#A3BE8C" />
    <SolidColorBrush x:Key="Warning" Color="#EBCB8B" />
    <SolidColorBrush x:Key="Destructive" Color="#BF616A" />

    <!-- Placeholder / overlay colors -->
    <SolidColorBrush x:Key="Overlay" Color="#80000000" />

</ResourceDictionary>
