<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================== Catppuccin Mocha Theme Colors ==================== -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BgPage" Color="#1E1E2E" />
    <SolidColorBrush x:Key="BgSurface" Color="#313244" />
    <SolidColorBrush x:Key="BgElevated" Color="#45475A" />
    <SolidColorBrush x:Key="BgPressed" Color="#585B70" />
    <SolidColorBrush x:Key="BgInput" Color="#313244" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#CDD6F4" />
    <SolidColorBrush x:Key="TextSecondary" Color="#BAC2DE" />
    <SolidColorBrush x:Key="TextMuted" Color="#A6ADC8" />

    <!-- Borders -->
    <SolidColorBrush x:Key="Border" Color="#45475A" />
    <SolidColorBrush x:Key="BorderStrong" Color="#585B70" />

    <!-- Accent (Catppuccin Blue) -->
    <SolidColorBrush x:Key="Accent" Color="#89B4FA" />

    <!-- Semantic Colors -->
    <SolidColorBrush x:Key="Success" Color="#A6E3A1" />
    <SolidColorBrush x:Key="Warning" Color="#F9E2AF" />
    <SolidColorBrush x:Key="Destructive" Color="#F38BA8" />

    <!-- Placeholder / overlay colors -->
    <SolidColorBrush x:Key="Overlay" Color="#80000000" />

</ResourceDictionary>
