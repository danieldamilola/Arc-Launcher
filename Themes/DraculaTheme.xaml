<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================== Dracula Theme Colors ==================== -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BgPage" Color="#282A36" />
    <SolidColorBrush x:Key="BgSurface" Color="#343746" />
    <SolidColorBrush x:Key="BgElevated" Color="#44475A" />
    <SolidColorBrush x:Key="BgPressed" Color="#6272A4" />
    <SolidColorBrush x:Key="BgInput" Color="#343746" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#F8F8F2" />
    <SolidColorBrush x:Key="TextSecondary" Color="#BD93F9" />
    <SolidColorBrush x:Key="TextMuted" Color="#6272A4" />

    <!-- Borders -->
    <SolidColorBrush x:Key="Border" Color="#44475A" />
    <SolidColorBrush x:Key="BorderStrong" Color="#6272A4" />

    <!-- Accent (Dracula Cyan) -->
    <SolidColorBrush x:Key="Accent" Color="#8BE9FD" />

    <!-- Semantic Colors -->
    <SolidColorBrush x:Key="Success" Color="#50FA7B" />
    <SolidColorBrush x:Key="Warning" Color="#FFB86C" />
    <SolidColorBrush x:Key="Destructive" Color="#FF5555" />

    <!-- Placeholder / overlay colors -->
    <SolidColorBrush x:Key="Overlay" Color="#80000000" />

</ResourceDictionary>
