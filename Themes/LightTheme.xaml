<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================== macOS Light Theme Colors ==================== -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BgPage" Color="#F2F2F7" />
    <SolidColorBrush x:Key="BgSurface" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BgElevated" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BgPressed" Color="#E5E5EA" />
    <SolidColorBrush x:Key="BgInput" Color="#FFFFFF" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#1D1D1F" />
    <SolidColorBrush x:Key="TextSecondary" Color="#6E6E73" />
    <SolidColorBrush x:Key="TextMuted" Color="#AEAEB2" />

    <!-- Borders -->
    <SolidColorBrush x:Key="Border" Color="#E5E5EA" />
    <SolidColorBrush x:Key="BorderStrong" Color="#D1D1D6" />

    <!-- Accent -->
    <SolidColorBrush x:Key="Accent" Color="#007AFF" />

    <!-- Semantic Colors -->
    <SolidColorBrush x:Key="Success" Color="#34C759" />
    <SolidColorBrush x:Key="Warning" Color="#FF9F0A" />
    <SolidColorBrush x:Key="Destructive" Color="#FF3B30" />

    <!-- Placeholder / overlay colors -->
    <SolidColorBrush x:Key="Overlay" Color="#40000000" />

</ResourceDictionary>
