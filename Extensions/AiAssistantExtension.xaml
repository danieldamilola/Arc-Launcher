<UserControl x:Class="Flow.Extensions.AiAssistantExtension"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="500">
    <Border Padding="{StaticResource Padding3}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Query label -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgInput}"
                    CornerRadius="{StaticResource RadiusSm}"
                    Padding="{StaticResource Padding2}"
                    Margin="0,0,0,10">
                <TextBlock x:Name="QueryLabel"
                           Text=""
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="{StaticResource FontSizeSm}"
                           TextWrapping="Wrap"
                           FontStyle="Italic" />
            </Border>

            <!-- Loading indicator -->
            <Border x:Name="LoadingBorder"
                    Grid.Row="1"
                    Visibility="Collapsed"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="ThinkingLabel"
                               Text="Thinking"
                               Foreground="{StaticResource Accent}"
                               FontSize="{StaticResource FontSizeLg}"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="AnimatedDots"
                               Text="..."
                               Foreground="{StaticResource Accent}"
                               FontSize="{StaticResource FontSizeLg}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- Response area -->
            <ScrollViewer x:Name="ResponseScroller"
                          Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBlock x:Name="ResponseText"
                           Text=""
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="{StaticResource FontSizeMd}"
                           TextWrapping="Wrap"
                           LineHeight="22" />
            </ScrollViewer>

            <!-- Missing API key hint -->
            <Border x:Name="NoKeyBorder"
                    Grid.Row="1"
                    Visibility="Collapsed"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="{StaticResource Padding2}">
                <TextBlock Text="Add your Groq API key in settings to use the AI assistant."
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="{StaticResource FontSizeSm}"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
            </Border>

            <!-- Status bar -->
            <TextBlock x:Name="StatusBar"
                       Grid.Row="2"
                       Text=""
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="11"
                       Margin="0,8,0,0" />
        </Grid>
    </Border>
</UserControl>
