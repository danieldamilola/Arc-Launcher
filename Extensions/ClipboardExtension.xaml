<UserControl x:Class="Flow.Extensions.ClipboardExtension"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="500">
    <Border Padding="{StaticResource Padding2}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       Text="Clipboard History"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="{StaticResource FontSizeSm}"
                       Margin="0,0,0,8" />

            <!-- Empty state -->
            <TextBlock x:Name="EmptyLabel"
                       Grid.Row="1"
                       Text="Clipboard is empty"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="{StaticResource FontSizeMd}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed" />

            <!-- Items list -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="ClipboardItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource Border}"
                                    BorderThickness="0,0,0,1"
                                    Padding="8,6"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="OnItemClicked"
                                    Tag="{Binding}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource BgContainer}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Content preview -->
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="{Binding TruncatedContent}"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="{StaticResource FontSizeSm}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="40"
                                               TextWrapping="NoWrap" />

                                    <!-- Timestamp -->
                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="{Binding TimeAgo}"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="11"
                                               Margin="0,2,0,0" />

                                    <!-- Copy hint -->
                                    <TextBlock Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                               Text="↩"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"
                                               ToolTip="Click to copy back to clipboard" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
