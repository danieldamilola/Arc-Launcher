<UserControl x:Class="Flow.Extensions.TimerExtension"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="180" d:DesignWidth="400">
    <Border Padding="{StaticResource Padding3}">
        <StackPanel VerticalAlignment="Center">
            <!-- Countdown display -->
            <TextBlock x:Name="CountdownText"
                       Text="00:00"
                       Foreground="{StaticResource TextPrimary}"
                       FontFamily="JetBrains Mono, Consolas, monospace"
                       FontSize="48"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12" />

            <!-- Progress bar -->
            <ProgressBar x:Name="TimerProgress"
                         Height="6"
                         Minimum="0"
                         Maximum="100"
                         Value="100"
                         Foreground="{StaticResource Accent}"
                         Background="{StaticResource BgInput}"
                         Margin="0,0,0,10" />

            <!-- Status label -->
            <TextBlock x:Name="StatusLabel"
                       Text="Running..."
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="{StaticResource FontSizeSm}"
                       HorizontalAlignment="Center" />

            <!-- Error -->
            <TextBlock x:Name="ErrorLabel"
                       Foreground="{StaticResource Destructive}"
                       FontSize="{StaticResource FontSizeSm}"
                       HorizontalAlignment="Center"
                       Visibility="Collapsed" />
        </StackPanel>
    </Border>
</UserControl>
