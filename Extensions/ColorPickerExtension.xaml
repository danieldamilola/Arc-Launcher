<UserControl x:Class="Flow.Extensions.ColorPickerExtension"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="140" d:DesignWidth="450">
    <Border Padding="{StaticResource Padding3}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Color swatch -->
            <Border x:Name="ColorSwatch"
                    Grid.Column="0"
                    Width="52"
                    Height="52"
                    CornerRadius="{StaticResource RadiusItem}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1"
                    Margin="0,0,16,0"
                    VerticalAlignment="Top" />

            <!-- Color details -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                <!-- Hex value -->
                <TextBlock x:Name="HexLabel"
                           Foreground="{StaticResource TextPrimary}"
                           FontFamily="JetBrains Mono, Consolas, monospace"
                           FontSize="{StaticResource FontSizeLg}"
                           Margin="0,0,0,6" />

                <!-- RGB -->
                <TextBlock x:Name="RgbLabel"
                           Foreground="{StaticResource TextSecondary}"
                           FontFamily="JetBrains Mono, Consolas, monospace"
                           FontSize="{StaticResource FontSizeSm}"
                           Margin="0,0,0,2" />

                <!-- HSL -->
                <TextBlock x:Name="HslLabel"
                           Foreground="{StaticResource TextSecondary}"
                           FontFamily="JetBrains Mono, Consolas, monospace"
                           FontSize="{StaticResource FontSizeSm}" />

                <!-- Error -->
                <TextBlock x:Name="ErrorLabel"
                           Foreground="{StaticResource Destructive}"
                           FontSize="{StaticResource FontSizeSm}"
                           Visibility="Collapsed" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
