<UserControl x:Class="Flow.Extensions.SettingsExtension"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="500">
    <Border Padding="{StaticResource Padding3}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- Header -->
                <TextBlock Text="Settings"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="{StaticResource FontSizeXl}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,16" />

                <!-- Theme -->
                <TextBlock Text="Theme"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="{StaticResource FontSizeSm}"
                           Margin="0,0,0,4" />
                <ComboBox x:Name="ThemeCombo"
                          SelectedIndex="0"
                          Margin="0,0,0,12"
                          Padding="8,4"
                          Background="{StaticResource BgInput}"
                          Foreground="{StaticResource TextPrimary}"
                          BorderBrush="{StaticResource Border}">
                    <ComboBoxItem Content="Dark" />
                    <ComboBoxItem Content="Light" />
                    <ComboBoxItem Content="System" />
                </ComboBox>

                <!-- Accent Color -->
                <TextBlock Text="Accent Color"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="{StaticResource FontSizeSm}"
                           Margin="0,0,0,4" />
                <TextBox x:Name="AccentColorBox"
                         Text="#5B6AF0"
                         FontFamily="JetBrains Mono, Consolas, monospace"
                         Margin="0,0,0,12"
                         Padding="8,4"
                         Background="{StaticResource BgInput}"
                         Foreground="{StaticResource TextPrimary}"
                         BorderBrush="{StaticResource Border}" />

                <!-- Font Size -->
                <TextBlock Text="Font Size"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="{StaticResource FontSizeSm}"
                           Margin="0,0,0,4" />
                <ComboBox x:Name="FontSizeCombo"
                          SelectedIndex="1"
                          Margin="0,0,0,12"
                          Padding="8,4"
                          Background="{StaticResource BgInput}"
                          Foreground="{StaticResource TextPrimary}"
                          BorderBrush="{StaticResource Border}">
                    <ComboBoxItem Content="Compact" />
                    <ComboBoxItem Content="Comfortable" />
                    <ComboBoxItem Content="Large" />
                </ComboBox>

                <!-- Opacity -->
                <TextBlock Text="Window Opacity"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="{StaticResource FontSizeSm}"
                           Margin="0,0,0,4" />
                <Slider x:Name="OpacitySlider"
                        Minimum="0.7"
                        Maximum="1.0"
                        Value="0.95"
                        TickFrequency="0.05"
                        IsSnapToTickEnabled="True"
                        Margin="0,0,0,4" />
                <TextBlock x:Name="OpacityLabel"
                           Text="95%"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11"
                           Margin="0,0,0,12" />

                <!-- Shortcut -->
                <TextBlock Text="Global Shortcut"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="{StaticResource FontSizeSm}"
                           Margin="0,0,0,4" />
                <TextBlock x:Name="ShortcutLabel"
                           Text="Alt+Space"
                           Foreground="{StaticResource TextPrimary}"
                           FontFamily="JetBrains Mono, Consolas, monospace"
                           FontSize="{StaticResource FontSizeMd}"
                           Margin="0,0,0,12"
                           Padding="8,4"
                           Background="{StaticResource BgInput}" />

                <!-- API Key -->
                <TextBlock Text="Groq API Key"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="{StaticResource FontSizeSm}"
                           Margin="0,0,0,4" />
                <TextBox x:Name="ApiKeyBox"
                         Text=""
                         FontFamily="JetBrains Mono, Consolas, monospace"
                         Margin="0,0,0,4"
                         Padding="8,4"
                         Background="{StaticResource BgInput}"
                         Foreground="{StaticResource TextPrimary}"
                         BorderBrush="{StaticResource Border}" />
                <TextBlock Text="Required for AI features. Get one at console.groq.com"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11"
                           Margin="0,0,0,16" />

                <!-- Save button and confirmation row -->
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="SaveButton"
                            Content="Save Settings"
                            Click="OnSaveClick"
                            Padding="16,8"
                            Background="{StaticResource Accent}"
                            Foreground="White"
                            BorderThickness="0"
                            HorizontalAlignment="Left"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6" />
                            </Style>
                        </Button.Resources>
                    </Button>

                    <TextBlock x:Name="SavedLabel"
                               Text="Saved!"
                               Foreground="{StaticResource Success}"
                               FontSize="{StaticResource FontSizeSm}"
                               Margin="16,0,0,0"
                               VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </StackPanel>

                <!-- Version -->
                <TextBlock x:Name="VersionLabel"
                           Text="Flow v1.0.0"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="11"
                           Margin="0,20,0,0" />
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
