<UserControl x:Class="Flow.Extensions.CalculatorExtension"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="120" d:DesignWidth="400">
    <Border Padding="{StaticResource Padding3}">
        <Grid>
            <!-- Expression display -->
            <TextBlock x:Name="ExpressionText"
                       Text=""
                       Foreground="{StaticResource TextSecondary}"
                       FontFamily="JetBrains Mono, Consolas, monospace"
                       FontSize="{StaticResource FontSizeSm}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,4"
                       VerticalAlignment="Top" />

            <!-- Result display -->
            <TextBlock x:Name="ResultText"
                       Text="= 0"
                       Foreground="{StaticResource TextPrimary}"
                       FontFamily="JetBrains Mono, Consolas, monospace"
                       FontSize="{StaticResource FontSizeXxl}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Margin="0,24,0,0" />

            <!-- Error display -->
            <TextBlock x:Name="ErrorText"
                       Text=""
                       Foreground="{StaticResource Destructive}"
                       FontFamily="JetBrains Mono, Consolas, monospace"
                       FontSize="{StaticResource FontSizeMd}"
                       VerticalAlignment="Bottom"
                       TextWrapping="Wrap"
                       Visibility="Collapsed" />
        </Grid>
    </Border>
</UserControl>
