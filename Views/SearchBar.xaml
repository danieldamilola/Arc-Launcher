<UserControl x:Class="Volt.Views.SearchBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Volt.ViewModels">

    <Grid Height="56">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>  <!-- search icon -->
            <ColumnDefinition Width="*"/>     <!-- text input -->
        </Grid.ColumnDefinitions>

        <!-- Search icon -->
        <Path Grid.Column="0"
              Margin="18,0,0,0"
              VerticalAlignment="Center"
              Data="M11 19C15.4183 19 19 15.4183 19 11C19 6.58172 15.4183 3 11 3C6.58172 3 3 6.58172 3 11C3 15.4183 6.58172 19 11 19ZM21 21L16.65 16.65"
              Stroke="{DynamicResource TextMuted}"
              StrokeThickness="1.8"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round"
              Width="18" Height="18"
              Stretch="Uniform"/>

        <!-- Text input -->
        <TextBox x:Name="SearchInput"
                 Grid.Column="1"
                 Margin="12,0,16,0"
                 VerticalAlignment="Center"
                 FontFamily="{DynamicResource UIFont}"
                 FontSize="17"
                 Foreground="{DynamicResource TextPrimary}"
                 Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                 TextChanged="OnTextChanged"/>

        <!-- Placeholder text -->
        <TextBlock x:Name="Placeholder"
                   Grid.Column="1"
                   Margin="12,0,16,0"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   FontFamily="{DynamicResource UIFont}"
                   FontSize="17"
                   Foreground="{DynamicResource TextMuted}"
                   Text="Search apps, files, clipboard…"/>
    </Grid>
</UserControl>
