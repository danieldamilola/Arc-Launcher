<UserControl x:Class="Flow.Views.SearchBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="56" d:DesignWidth="680">

    <Grid Height="56" Background="Transparent">
        <Grid.ColumnDefinitions>
            <!-- Search icon column -->
            <ColumnDefinition Width="52" />
            <!-- Input -->
            <ColumnDefinition Width="*" />
            <!-- ⌥Space hint -->
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Search icon — 18px, strokeWidth 1.5, TextMuted -->
        <Viewbox Grid.Column="0"
                 Width="18" Height="18"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
            <Canvas Width="24" Height="24">
                <Ellipse Canvas.Left="3" Canvas.Top="3"
                         Width="14" Height="14"
                         Stroke="{StaticResource TextSecondary}"
                         StrokeThickness="1.8"
                         Fill="Transparent" />
                <Line X1="15.5" Y1="15.5" X2="21" Y2="21"
                      Stroke="{StaticResource TextSecondary}"
                      StrokeThickness="1.8"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round" />
            </Canvas>
        </Viewbox>

        <!-- Input — DM Sans 17px, always focused, no border -->
        <Grid Grid.Column="1">
            <TextBox x:Name="SearchInput"
                     Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="{StaticResource DefaultFontFamily}"
                     FontSize="17"
                     Foreground="{StaticResource TextPrimary}"
                     Background="Transparent"
                     BorderThickness="0"
                     VerticalContentAlignment="Center"
                     TextChanged="SearchInput_TextChanged" />

            <!-- Placeholder — collapsed when input has text -->
            <TextBlock x:Name="Placeholder"
                       Text="Type anything..."
                       FontFamily="{StaticResource DefaultFontFamily}"
                       FontSize="17"
                       Foreground="{StaticResource TextSecondary}"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False" />
        </Grid>

        <!-- ⌥Space hint — DM Mono 11px, faint -->
        <Border x:Name="HintBadge"
                Grid.Column="2"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="6,3"
                Margin="0,0,16,0"
                VerticalAlignment="Center">
            <TextBlock Text="⌥ Space"
                       FontFamily="{StaticResource MonoFontFamily}"
                       FontSize="11"
                       Foreground="{StaticResource TextMuted}" />
        </Border>
    </Grid>
</UserControl>
