<UserControl x:Class="Flow.Views.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Flow.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="680">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="{StaticResource BgPage}">
        <StackPanel>

            <!-- ═══ APPEARANCE ═══ -->
            <TextBlock Text="APPEARANCE"
                       FontFamily="{StaticResource DefaultFontFamily}"
                       FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="16,20,16,4" />

            <!-- Theme -->
            <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                <Grid Height="48" Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Theme" FontFamily="{StaticResource DefaultFontFamily}"
                               FontSize="14" FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{x:Static vm:SettingsViewModel.ThemeOptions}"
                              SelectedItem="{Binding Theme}"
                              Width="140" Height="32" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Font size -->
            <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                <Grid Height="48" Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Font size" FontFamily="{StaticResource DefaultFontFamily}"
                               FontSize="14" FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{x:Static vm:SettingsViewModel.FontSizeOptions}"
                              SelectedItem="{Binding FontSize}"
                              Width="140" Height="32" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Border radius -->
            <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                <Grid Height="48" Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Border radius" FontFamily="{StaticResource DefaultFontFamily}"
                               FontSize="14" FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{x:Static vm:SettingsViewModel.BorderRadiusOptions}"
                              SelectedItem="{Binding BorderRadius}"
                              Width="140" Height="32" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Window opacity -->
            <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                <Grid Height="48" Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="40" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Window opacity" FontFamily="{StaticResource DefaultFontFamily}"
                               FontSize="14" FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                    <Slider Grid.Column="1"
                            Minimum="0.70" Maximum="1.00" SmallChange="0.01"
                            Value="{Binding Opacity}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding Opacity, StringFormat={}{0:P0}}"
                               FontFamily="{StaticResource MonoFontFamily}"
                               FontSize="12" Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <!-- ═══ AI ═══ -->
            <TextBlock Text="AI"
                       FontFamily="{StaticResource DefaultFontFamily}"
                       FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="16,20,16,4" />

            <!-- Groq API Key -->
            <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                <Grid Height="48" Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="200" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Groq API Key" FontFamily="{StaticResource DefaultFontFamily}"
                               FontSize="14" FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding GroqApiKey, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{StaticResource MonoFontFamily}" FontSize="12"
                             Height="32" VerticalContentAlignment="Center" Padding="8,0"
                             Background="{StaticResource BgContainer}"
                             BorderBrush="{StaticResource Border}" BorderThickness="1" />
                </Grid>
            </Border>

            <!-- ═══ SHORTCUTS ═══ -->
            <TextBlock Text="SHORTCUTS"
                       FontFamily="{StaticResource DefaultFontFamily}"
                       FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="16,20,16,4" />

            <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                <Grid Height="48" Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Open Flow" FontFamily="{StaticResource DefaultFontFamily}"
                               FontSize="14" FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                    <Border Grid.Column="1"
                            BorderBrush="{StaticResource Border}" BorderThickness="1"
                            CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Shortcut}"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="12" Foreground="{StaticResource TextSecondary}" />
                    </Border>
                </Grid>
            </Border>

            <!-- ═══ DATA ═══ -->
            <TextBlock Text="DATA"
                       FontFamily="{StaticResource DefaultFontFamily}"
                       FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="16,20,16,4" />

            <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                <Grid Height="48" Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Clear usage history" FontFamily="{StaticResource DefaultFontFamily}"
                               FontSize="14" FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="Clear"
                            Width="72" Height="30" VerticalAlignment="Center"
                            Foreground="{StaticResource Destructive}"
                            BorderBrush="{StaticResource Destructive}" />
                </Grid>
            </Border>

            <!-- ═══ Actions ═══ -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="16,16,16,4">
                <Button Content="Reset" Command="{Binding ResetCommand}"
                        Width="72" Height="32" Margin="0,0,8,0" />
                <Button Content="Cancel" Command="{Binding CancelCommand}"
                        Width="72" Height="32" Margin="0,0,8,0" />
                <Button Content="Save" Command="{Binding SaveCommand}"
                        Width="72" Height="32"
                        Background="{StaticResource Accent}"
                        Foreground="{StaticResource SelectedText}"
                        BorderThickness="0" />
            </StackPanel>

            <!-- Version -->
            <TextBlock Text="Flow v0.1.0"
                       FontFamily="{StaticResource DefaultFontFamily}"
                       FontSize="11" Foreground="{StaticResource TextMuted}"
                       HorizontalAlignment="Right"
                       Margin="16,4,16,20" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
