<UserControl x:Class="Flow.Views.DetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="280">

    <!-- Root: hidden when ShowDetailPanel is false -->
    <Border x:Name="Root"
            Width="280"
            Background="{StaticResource BgSurface}"
            BorderBrush="{StaticResource Border}"
            BorderThickness="1,0,0,0"
            CornerRadius="0"
            Padding="20">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Panel header -->
            <TextBlock Grid.Row="0"
                       Text="Details"
                       FontSize="{StaticResource FontSizeBase}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="0,0,0,12" />

            <!-- Content area — switches based on DetailContent type -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">

                <StackPanel x:Name="ContentStack">

                    <!-- Shown for SearchResult detail -->
                    <StackPanel x:Name="AppDetailSection" Visibility="Collapsed">
                        <!-- Name -->
                        <TextBlock x:Name="AppName"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <!-- Icon placeholder -->
                        <Border Width="48" Height="48"
                                Background="{StaticResource BgContainer}"
                                CornerRadius="8"
                                Margin="0,0,0,12">
                            <TextBlock Text="&#x1F4C4;"
                                       FontSize="24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <!-- Path -->
                        <TextBlock x:Name="AppPath"
                                   FontSize="{StaticResource FontSizeSm}"
                                   Foreground="{StaticResource TextSecondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <!-- Size / Last modified -->
                        <TextBlock x:Name="AppMeta"
                                   FontSize="{StaticResource FontSizeSm}"
                                   Foreground="{StaticResource TextMuted}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />
                        <!-- "Press Enter to open" hint -->
                        <TextBlock Text="Press Enter to open"
                                   FontSize="{StaticResource FontSizeSm}"
                                   Foreground="{StaticResource Accent}" />
                    </StackPanel>

                    <!-- Shown for AI responses -->
                    <StackPanel x:Name="AiDetailSection" Visibility="Collapsed">
                        <TextBlock x:Name="AiHeader"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Blue}"
                                   Text="AI Assistant"
                                   Margin="0,0,0,8" />
                        <TextBlock x:Name="AiContent"
                                   FontSize="{StaticResource FontSizeBase}"
                                   Foreground="{StaticResource TextPrimary}"
                                   TextWrapping="Wrap"
                                   LineHeight="22" />
                        <!-- AI loading indicator -->
                        <StackPanel x:Name="AiLoadingIndicator"
                                    Orientation="Horizontal"
                                    Visibility="Collapsed">
                            <TextBlock Text="Thinking"
                                       FontSize="{StaticResource FontSizeSm}"
                                       Foreground="{StaticResource TextMuted}" />
                            <TextBlock Text="..."
                                       FontSize="{StaticResource FontSizeSm}"
                                       Foreground="{StaticResource TextMuted}" />
                        </StackPanel>
                        <!-- AI error -->
                        <TextBlock x:Name="AiErrorText"
                                   FontSize="{StaticResource FontSizeSm}"
                                   Foreground="#EF4444"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed" />
                    </StackPanel>

                    <!-- Shown for extension output -->
                    <StackPanel x:Name="ExtensionDetailSection" Visibility="Collapsed">
                        <TextBlock x:Name="ExtensionHeader"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,0,0,8" />
                        <TextBlock x:Name="ExtensionContent"
                                   FontSize="{StaticResource FontSizeBase}"
                                   Foreground="{StaticResource TextPrimary}"
                                   TextWrapping="Wrap"
                                   LineHeight="22" />
                    </StackPanel>

                    <!-- Fallback: empty state -->
                    <TextBlock x:Name="EmptyHint"
                               Text="Select a result to see details"
                               FontSize="{StaticResource FontSizeSm}"
                               Foreground="{StaticResource TextMuted}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>

            <!-- Footer hint -->
            <TextBlock Grid.Row="2"
                       FontSize="10"
                       Foreground="{StaticResource TextMuted}"
                       Margin="0,12,0,0"
                       Text="&#x2191;&#x2193; Navigate  &#x21B5; Open  Esc Dismiss" />
        </Grid>
    </Border>
</UserControl>
