<UserControl x:Class="Flow.Views.ResultItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="52" d:DesignWidth="680">

    <!-- Outer grid: left accent rail (2px) + row content -->
    <Grid x:Name="RootGrid"
          Height="52"
          Cursor="Hand"
          MouseLeftButtonDown="OnItemClicked"
          MouseEnter="OnMouseEnter"
          MouseLeave="OnMouseLeave">
        <Grid.ColumnDefinitions>
            <!-- 2px left accent rail (type colour, visible only when selected) -->
            <ColumnDefinition Width="2" />
            <!-- Row content -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left accent rail -->
        <Rectangle x:Name="AccentRail"
                   Grid.Column="0"
                   Fill="{StaticResource AccentRailApp}"
                   Visibility="Collapsed" />

        <!-- Row background -->
        <Border x:Name="RowBg"
                Grid.Column="1"
                Background="Transparent">

            <Grid Margin="14,0,16,0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <!-- Icon 20px -->
                    <ColumnDefinition Width="20" />
                    <!-- Gap -->
                    <ColumnDefinition Width="12" />
                    <!-- Name + subtitle -->
                    <ColumnDefinition Width="*" />
                    <!-- Kbd hint -->
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- ── App icon (20×20) ── -->
                <Image Grid.Column="0"
                       Width="20" Height="20"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Source="{Binding Icon, Converter={StaticResource PathToIcon}}"
                       Stretch="Uniform"
                       VerticalAlignment="Center" />

                <!-- ── Name + subtitle ── -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock x:Name="NameText"
                               Text="{Binding Name}"
                               FontFamily="{StaticResource DefaultFontFamily}"
                               FontSize="14"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="SubtitleText"
                               Text="{Binding Subtitle}"
                               FontFamily="{StaticResource DefaultFontFamily}"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondary}"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,2,0,0"
                               Visibility="Collapsed" />
                </StackPanel>

                <!-- ── Keyboard shortcut badge — DM Mono 11px ── -->
                <Border Grid.Column="3"
                        x:Name="EnterHint"
                        Background="{StaticResource BgContainer}"
                        CornerRadius="4"
                        Padding="6,2"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                    <TextBlock Text="↵"
                               FontFamily="{StaticResource MonoFontFamily}"
                               FontSize="11"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextSecondary}" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
