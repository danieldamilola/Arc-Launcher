<UserControl x:Class="Flow.Views.ResultsList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Flow.Views">

    <Grid Background="Transparent" MinHeight="52">

        <!-- Results scroll area — flush, no padding -->
        <ScrollViewer x:Name="ResultsScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Focusable="False">
            <ItemsControl x:Name="ResultsItems"
                          ItemsSource="{Binding Results}"
                          BorderThickness="0"
                          Background="Transparent"
                          Focusable="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel IsVirtualizing="True"
                                               VirtualizationMode="Recycling" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:ResultItem DataContext="{Binding}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state: no query typed yet -->
        <StackPanel x:Name="EmptyState"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed"
                    Margin="0,32">
            <TextBlock Text="Start typing to search apps and files."
                       FontFamily="{StaticResource DefaultFontFamily}"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondary}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- No results state: query typed but nothing found -->
        <StackPanel x:Name="NoResultsState"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed"
                    Margin="0,32">
            <TextBlock x:Name="NoResultsText"
                       FontFamily="{StaticResource DefaultFontFamily}"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondary}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Try something else or press ↵ to ask AI."
                       FontFamily="{StaticResource DefaultFontFamily}"
                       FontSize="12"
                       Foreground="{StaticResource TextMuted}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0" />
        </StackPanel>

    </Grid>
</UserControl>
