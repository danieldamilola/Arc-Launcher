<UserControl x:Class="Volt.Views.ResultsList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Volt.Views"
             xmlns:models="clr-namespace:Volt.Models"
             xmlns:conv="clr-namespace:Volt.Converters">

    <UserControl.Resources>

        <!-- Section label template -->
        <DataTemplate x:Key="SectionTemplate" DataType="{x:Type models:SectionLabel}">
            <TextBlock Text="{Binding Title}"
                       FontFamily="{DynamicResource UIFont}"
                       FontSize="{DynamicResource FontXs}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextMuted}"
                       Padding="16,8,16,4"
                       TextOptions.TextFormattingMode="Display"/>
        </DataTemplate>

        <!-- Result row template -->
        <DataTemplate x:Key="ResultTemplate" DataType="{x:Type models:SearchResult}">
            <Grid x:Name="RowRoot" Height="52"
                  Margin="4,0"
                  Background="Transparent"
                  MouseEnter="OnRowMouseEnter"
                  MouseLeave="OnRowMouseLeave"
                  MouseLeftButtonDown="OnRowClick"
                  Cursor="Hand">

                <Grid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Run as Administrator"
                                  Command="{Binding DataContext.RunAsAdminCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  InputGestureText="Ctrl+Shift+Enter"/>
                        <MenuItem Header="Open file location"
                                  Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  InputGestureText="Ctrl+Enter"/>
                    </ContextMenu>
                </Grid.ContextMenu>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- accent rail -->
                    <ColumnDefinition Width="40"/>     <!-- icon -->
                    <ColumnDefinition Width="*"/>      <!-- name + subtitle -->
                    <ColumnDefinition Width="Auto"/>   <!-- pin button -->
                    <ColumnDefinition Width="Auto"/>   <!-- shortcut hint -->
                    <ColumnDefinition Width="8"/>      <!-- right margin -->
                </Grid.ColumnDefinitions>

                <!-- Selection accent rail (2px left strip) -->
                <Border x:Name="AccentRail"
                        Grid.Column="0"
                        Width="2" Margin="0,8"
                        CornerRadius="1"
                        Background="{DynamicResource Accent}"
                        Visibility="Collapsed"/>

                <!-- Row background (rounded rect) -->
                <Border x:Name="RowBg"
                        Grid.Column="0" Grid.ColumnSpan="5"
                        CornerRadius="{DynamicResource RadiusRow}"
                        Background="Transparent"/>

                <!-- App icon (real extracted icon) -->
                <Image Grid.Column="1"
                       Width="20" Height="20"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.Source>
                        <Binding Path="IconPath">
                            <Binding.Converter>
                                <conv:PathToIconConverter/>
                            </Binding.Converter>
                        </Binding>
                    </Image.Source>
                    <Image.Style>
                        <Style TargetType="Image">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IconPath}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <!-- Name + subtitle -->
                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <TextBlock x:Name="NameText"
                               Text="{Binding Name}"
                               FontFamily="{DynamicResource UIFont}"
                               FontSize="{DynamicResource FontBase}"
                               FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimary}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="SubtitleText"
                               Text="{Binding Subtitle}"
                               FontFamily="{DynamicResource UIFont}"
                               FontSize="{DynamicResource FontSm}"
                               Foreground="{DynamicResource TextSecondary}"
                               TextTrimming="CharacterEllipsis"
                               Visibility="Collapsed"/>
                </StackPanel>

                <!-- Pin button -->
                <Button x:Name="PinBtn"
                        Grid.Column="3"
                        Width="28" Height="28" Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Pin (Ctrl+P)"
                        Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"
                        Visibility="Collapsed">
                    <Path Data="M16 4v4l-2 2v5l2 2v2h-5v4l-1 1-1-1v-4H6v-2l2-2v-5l-2-2V4h10z"
                          Width="14" Height="14" Stretch="Uniform"
                          Fill="{DynamicResource TextMuted}"/>
                </Button>

                <!-- Enter hint badge -->
                <Border x:Name="EnterHint"
                        Grid.Column="4"
                        CornerRadius="{DynamicResource RadiusSm}"
                        Background="{DynamicResource SurfaceLow}"
                        Padding="6,2"
                        Visibility="Collapsed"
                        VerticalAlignment="Center">
                    <TextBlock Text="↵"
                               FontFamily="{DynamicResource MonoFont}"
                               FontSize="{DynamicResource FontXs}"
                               Foreground="{DynamicResource TextMuted}"/>
                </Border>
            </Grid>

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                    <Setter TargetName="PinBtn" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="PinBtn" Property="Opacity" Value="1.0"/>
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="PinBtn" Property="Visibility" Value="Visible"/>
                </Trigger>
                <!-- Pin only for clipboard: collapse for all other types -->
                <DataTrigger Binding="{Binding Type}" Value="App">
                    <Setter TargetName="PinBtn" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="File">
                    <Setter TargetName="PinBtn" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Action">
                    <Setter TargetName="PinBtn" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Action">
                    <Setter TargetName="RowRoot" Property="Cursor" Value="Arrow"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Template selector -->
        <local:ResultTemplateSelector x:Key="TemplateSelector"
                                      SectionTemplate="{StaticResource SectionTemplate}"
                                      ResultTemplate="{StaticResource ResultTemplate}"/>
    </UserControl.Resources>

    <ListBox x:Name="ResultsBox"
             ItemsSource="{Binding Results}"
             ItemTemplateSelector="{StaticResource TemplateSelector}"
             SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
             SelectionChanged="OnSelectionChanged"
             HorizontalContentAlignment="Stretch"
             Padding="0,4,0,8"
             Focusable="False"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             ScrollViewer.CanContentScroll="False"/>
</UserControl>
